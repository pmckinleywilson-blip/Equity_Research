# Database (Neon PostgreSQL free tier, or local SQLite)
DATABASE_URL=sqlite:///./sp500events.db
# DATABASE_URL=postgresql://user:pass@host/dbname

# Security
SECRET_KEY=change-me-to-a-random-string

# Email service (Resend free tier: 100 emails/day)
RESEND_API_KEY=
INVITE_FROM_EMAIL=invites@sp500events.com

# Site URL (used for generating links)
SITE_URL=http://localhost:8000

# Data source API keys
FINNHUB_API_KEY=
SEC_EDGAR_USER_AGENT=SP500Events admin@sp500events.com

# Rate limiting
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_API_KEY=300/minute
